# Copy to .env — never commit real keys
PORT=8787
NODE_ENV=development

# Claude (vision + text). Required for cloud mode.
CLAUDE_API_KEY=your-claude-api-key-here

# AI: claude | auto | mock
# - claude: require CLAUDE_API_KEY (default).
# - auto: Claude when key set, else MockAiProvider (deterministic heuristics — local fallback).
# - mock: always offline heuristics (CI / beginners).
AI_ENGINE=claude

# Speech: auto | edge
# Claude does not provide speech synthesis in this service; auto resolves to edge.
TTS_ENGINE=auto
TTS_EDGE_VOICE=en-US-AriaNeural

CLAUDE_VISION_MODEL=claude-3-7-sonnet-latest
CLAUDE_TEXT_MODEL=claude-3-5-haiku-latest
CLAUDE_MAX_TOKENS=1600

# SQLite session store (cart + profile). Set SQLITE_ENABLED=false for RAM-only.
SQLITE_ENABLED=true
SQLITE_PATH=./data/shelvesense.db

# OCR (tesseract.js) for POST /api/profile/ocr — first run downloads language data.
OCR_ENABLED=true
# Resize / normalize / sharpen before OCR (recommended for real packaging + shelves).
OCR_PREPROCESS=true

CORS_ORIGINS=
