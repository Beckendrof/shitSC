{
  "name": "shelvesense-server",
  "version": "0.1.0",
  "private": true,
  "description": "ShelfSense intelligence layer — Express + TypeScript for Snap Spectacles grocery health assistant",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "samples:generate": "node scripts/generate-samples.cjs",
    "verify:samples": "tsx scripts/verify-samples.ts",
    "samples:real:fetch": "node scripts/fetch-real-product-samples.mjs",
    "verify:real": "tsx scripts/verify-real-samples.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "edge-tts": "^1.0.1",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
